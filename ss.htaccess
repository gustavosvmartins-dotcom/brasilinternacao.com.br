RewriteEngine On

# Redireciona variações de host problemáticas para a home
RewriteCond %{HTTP_HOST} ^www\.grupogilardi\.com\.br\.brasilinternacao\.com\.br$ [NC,OR]
RewriteCond %{HTTP_HOST} ^www\.grupogilardi\.brasilinternacao\.com\.br$ [NC,OR]
RewriteCond %{HTTP_HOST} ^grupogilardi\.brasilinternacao\.com\.br$ [NC,OR]
RewriteCond %{HTTP_HOST} ^autodiscover\.brasilinternacao\.com\.br$ [NC,OR]
RewriteCond %{HTTP_HOST} ^mail\.brasilinternacao\.com\.br$ [NC,OR]
RewriteCond %{HTTP_HOST} ^cpcontacts\.brasilinternacao\.com\.br$ [NC,OR]
RewriteCond %{HTTP_HOST} ^www\.loreinpratas\.brasilinternacao\.com\.br$ [NC,OR]
RewriteCond %{HTTP_HOST} ^www\.viversemvicios\.brasilinternacao\.com\.br$ [NC,OR]
RewriteCond %{HTTP_HOST} ^cpanel\.brasilinternacao\.com\.br$ [NC,OR]
RewriteCond %{HTTP_HOST} ^webmail\.brasilinternacao\.com\.br$ [NC,OR]
RewriteCond %{HTTP_HOST} ^grupogilardi\.com\.br\.brasilinternacao\.com\.br$ [NC,OR]
RewriteCond %{HTTP_HOST} ^www\.grupomatiastratamentos\.brasilinternacao\.com\.br$ [NC,OR]
RewriteCond %{HTTP_HOST} ^cpcalendars\.brasilinternacao\.com\.br$ [NC,OR]
RewriteCond %{HTTP_HOST} ^webdisk\.brasilinternacao\.com\.br$ [NC,OR]
RewriteCond %{HTTP_HOST} ^www\.brasilinternacoes\.brasilinternacao\.com\.br$ [NC]
RewriteRule ^ https://brasilinternacao.com.br/ [R=301,L]

# Redireciona versões com www da home para a home canônica
RewriteCond %{HTTP_HOST} ^www\.brasilinternacao\.com\.br$ [NC]
RewriteRule ^$ https://brasilinternacao.com.br/ [R=301,L]

# URLs específicas para redirecionar para a home
